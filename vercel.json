{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/screenshots/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "http://streamflixvip.online/(.*)",
      "destination": "https://streamflixvip.online/$1",
      "permanent": true
    },
    {
      "source": "http://www.streamflixvip.online/(.*)",
      "destination": "https://streamflixvip.online/$1",
      "permanent": true
    },
    {
      "source": "https://www.streamflixvip.online/(.*)",
      "destination": "https://streamflixvip.online/$1",
      "permanent": true
    }
  ]
}
